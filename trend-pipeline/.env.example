ANTHROPIC_API_KEY=your_key_here
STRIPE_SECRET_KEY=your_key_here
STRIPE_PUBLISHABLE_KEY=your_key_here

# Upstash Redis — create a database at https://console.upstash.com
# Copy the REST URL and token into your Vercel env vars (and local .env for dev).
# Leave blank to fall back to in-memory store (data lost on restart).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: protects /api/run from unauthorized access.
# Set the same value in Vercel env vars. Then call: /api/run?secret=your_value
CRON_SECRET=
